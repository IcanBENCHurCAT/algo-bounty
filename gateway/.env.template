# AlgoBounty Environment Configuration Template
# Copy this file to .env and fill in the values.

# ── Supabase PostgreSQL (PRIMARY DB) ─────────────────────────────────
# Connection string for Supabase PostgreSQL
SUPABASE_URL=postgresql://<project-ref>.supabase.co:5432/postgres

# Supabase service role key (bypasses RLS — used by the backend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend Supabase config
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── Algorand Network ─────────────────────────────────────────────────
ALGORAND_NETWORK=testnet

# ── Platform Wallet ──────────────────────────────────────────────────
PLATFORM_PRIVATE_KEY=

# ── Testnet (production fallback) ────────────────────────────────────
TESTNET_ALGOD_URL=https://testnet-api.algonode.cloud
TESTNET_INDEXER_URL=https://testnet-indexer.algonode.cloud

# ── Sandbox (local dev only) ────────────────────────────────────────
ALGOD_ADDRESS=http://10.0.0.67:4001
ALGOD_TOKEN=
INDEXER_ADDRESS=http://10.0.0.67:8980
INDEXER_TOKEN=
TESTNET_ALGOD_TOKEN=

# ── JWT / Webhooks ──────────────────────────────────────────────────
SECRET_KEY=your-jwt-secret-key-change-in-prod
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── GitHub App Integration ──────────────────────────────────────────
# Optional: Use a GitHub App for higher rate limits and better integration
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_INSTALLATION_ID=
# If not using GitHub App, provide a personal access token:
GITHUB_TOKEN=

# ── Database Connection Pool ─────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
